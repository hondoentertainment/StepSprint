# Active dev DB: SQLite (prisma/schema.prisma, @prisma/adapter-better-sqlite3)
DATABASE_URL="file:./dev.db"

# Production DB: PostgreSQL. On Vercel, the Marketplace Neon integration
# auto-injects POSTGRES_PRISMA_URL (pooled) and POSTGRES_URL_NON_POOLING
# (direct); scripts/vercel-build.mjs aliases them to DATABASE_URL / DIRECT_URL.
# For local Postgres parity, point DATABASE_URL at docker-compose Postgres:
# DATABASE_URL="postgresql://stepsprint:stepsprint@localhost:5432/stepsprint"
# DIRECT_URL="postgresql://stepsprint:stepsprint@localhost:5432/stepsprint"

# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"

APP_ORIGIN="http://localhost:5173"

# Optional: comma-separated extra browser origins for CORS (custom domain, staging SPA).
#APP_ORIGIN_ALLOWLIST="https://www.example.com,https://staging.example.com"

# Optional (staging only): allow any https://*.vercel.app Origin for Vercel preview deploys.
# Do not enable on production unless you accept preview deployments calling this API.
#APP_ALLOW_VERCEL_PREVIEW_ORIGINS=false

# Production same-origin (single Vercel project): API_PUBLIC_ORIGIN defaults
# to APP_ORIGIN. Override only if you intentionally split the API onto a
# different hostname (custom domain for /api), so OAuth redirect URIs and
# Apple Health Shortcuts know the right host.
#API_PUBLIC_ORIGIN="http://localhost:3001"

# ---------------------------------------------------------------------------
# Web client (Vite)
# ---------------------------------------------------------------------------
# Same-origin Vercel = leave VITE_API_URL unset; the SPA uses relative /api paths.
# Set this only if you split the API onto a different host (custom API domain
# or fallback host); the Devices page and iOS Shortcuts use it as the POST base.
#VITE_API_URL="https://your-api.example.com"

# Opt-in reminders: evaluate enrolled challenges near this local clock hour (`0`-`23`)
#REMINDER_NOTIFICATION_HOUR_LOCAL=17

# On Vercel: set REMINDER_USE_EXTERNAL_CRON=true (the in-process scheduler is
# auto-disabled when VERCEL=1; the flag silences the startup warning) and set
# CRON_SECRET — Vercel Cron auto-attaches `Authorization: Bearer <CRON_SECRET>`.
# REMINDER_CRON_SECRET is still accepted server-side for backwards compat.
#REMINDER_USE_EXTERNAL_CRON=true
#CRON_SECRET="min-16-char-secret-for-bearer-cron"

# ─── Timezones ────────────────────────────────────────────────────────────────
DEFAULT_CHALLENGE_TZ="America/Chicago"

# Seed admin password. Set on the FIRST Vercel deploy so the admin lands with
# a known credential. Omit on later deploys; the seed only runs at build time
# and won't rotate the existing admin password.
# ADMIN_PASSWORD="password123"

# ---------------------------------------------------------------------------
# Email (transactional — password reset, email verification)
# Priority: RESEND_API_KEY (HTTP API) > SMTP_* > dev-mode log
# In production the API refuses to start without one of these; override only
# for emergency bring-up via ALLOW_PRODUCTION_WITHOUT_EMAIL=true.
# ---------------------------------------------------------------------------
# Option A: Resend (recommended) — POST /emails over HTTPS, no SMTP egress.
#   1. Create an API key at https://resend.com/api-keys
#   2. Verify your sending domain at https://resend.com/domains and copy the
#      DNS records into your DNS host (TXT for SPF + DKIM; DMARC optional).
#   3. Set RESEND_API_KEY and SMTP_FROM in Vercel → Settings → Environment
#      Variables. The `From` address must match the verified domain.
# RESEND_API_KEY=re_xxx
# SMTP_FROM="StepSprint <noreply@yourdomain.com>"

# Option B: Raw SMTP (SendGrid, Postmark, SES, etc.) — used only when
# RESEND_API_KEY is unset.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-password
# SMTP_FROM="StepSprint <noreply@yourdomain.com>"

# ---------------------------------------------------------------------------
# Push notifications (Web Push / VAPID)
# Generate keys: npx web-push generate-vapid-keys
# ---------------------------------------------------------------------------
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# ---------------------------------------------------------------------------
# OAuth integrations (optional — omit to disable Fitbit / Google Fit connect)
# Register redirect URIs in each provider's console against your Vercel host
# (or http://localhost:3001 for local dev with the Vite proxy). Examples:
#   http://localhost:3001/api/integrations/fitbit/callback
#   https://your-app.vercel.app/api/integrations/fitbit/callback
# ---------------------------------------------------------------------------
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Garmin Connect Developer Program (OAuth 2 + PKCE; requires approved developer app).
# Register this exact redirect against your Vercel host:
#   https://your-app.vercel.app/api/integrations/garmin/callback
# Optional space-separated Garmin authorize scopes when your registration requires passing scope:
#GARMIN_OAUTH_SCOPE=

# GARMIN_CLIENT_ID=
# GARMIN_CLIENT_SECRET=

# Optional: expose Swagger in production (default off when NODE_ENV=production)
# OPENAPI_DOCS_ENABLED=true

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
# LOG_LEVEL=info   # trace | debug | info | warn | error (default: info)
#
# Sentry (server) — DSN from a Sentry project's "Client Keys" page. The API
# initialises Sentry from api/index.js BEFORE Express loads, so unhandled
# errors and the cron route's explicit captures both flow to your project.
# SENTRY_DSN=
# Optional explicit release for Sentry + /api/health (else derived from
# VERCEL_GIT_COMMIT_SHA, GITHUB_SHA, COMMIT_REF, etc.)
# SENTRY_RELEASE=stepsprint-api@abc1234
#
# Sentry (browser)
# VITE_SENTRY_DSN=
# Optional explicit release tag for the SPA (else derived from VERCEL_GIT_COMMIT_SHA / GITHUB_SHA in vite.config.ts)
# VITE_SENTRY_RELEASE=stepsprint-client@abc1234
#
# Source-map upload during `vite build` — set ALL THREE on the Vercel project
# (or your CI) so @sentry/vite-plugin uploads hidden maps for the release tag
# above. The token must be an "Internal Integration" with project:releases
# scope. Source maps are emitted as `build.sourcemap: "hidden"` so they are
# not served to browsers.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
#
# PostHog product analytics
# VITE_POSTHOG_KEY=
# VITE_API_URL — see "Web client (Vite)" section near top of this file (split hosting / Shortcuts).
# After legal/privacy copy is reviewed for your launch, set at Vite build time to hide the draft banner on Privacy/Terms.
#VITE_LEGAL_CONTENT_REVIEWED=true

# Production only: allow API to start without Resend/SMTP (not for public launches; registration and reset email will not work).
#ALLOW_PRODUCTION_WITHOUT_EMAIL=false
