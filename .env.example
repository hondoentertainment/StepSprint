DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stepsprint?schema=public"
JWT_SECRET="change-me-to-a-long-random-secret"
APP_ORIGIN="http://localhost:5173"
# Public URL of this API (OAuth redirects). Local default is http://localhost:3001 if unset in code.
# API_PUBLIC_URL="http://localhost:3001"
DEFAULT_CHALLENGE_TZ="America/Chicago"
# Optional SMTP (invite + reminder emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# Cron for step reminders (default 8pm America/Chicago daily)
# REMINDER_CRON="0 20 * * *"
# REMINDER_TZ="America/Chicago"
# Cron for fitness import sync (default every 4 hours at :20 UTC)
# FITNESS_SYNC_CRON="20 */4 * * *"
# FITNESS_SYNC_TZ="Etc/UTC"
# Set to 1 to log non-health HTTP requests (method, path, status, duration)
# LOG_HTTP=1
# Shown in /api/health JSON when set (e.g. CI or container image digest)
# COMMIT_SHA=
# Fitbit OAuth (https dev.fitbit.com app + callback URL = {API_PUBLIC_URL}/api/integrations/fitness/oauth/fitbit/callback)
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=
# Google OAuth (Fitness activity scope; callback = {API_PUBLIC_URL}/api/integrations/fitness/oauth/google_fit/callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
