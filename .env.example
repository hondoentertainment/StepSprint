# Active dev DB: SQLite (prisma/schema.prisma, @prisma/adapter-better-sqlite3)
DATABASE_URL="file:./dev.db"

# Production DB: PostgreSQL (set in Render — auto-wired from stepsprint-db)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stepsprint?schema=public"

# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"

APP_ORIGIN="http://localhost:5173"

# Public URL where browsers reach **this Express app**. Defaults to APP_ORIGIN.
# Split hosting (prod): set APP_ORIGIN to the Vercel SPA and API_PUBLIC_ORIGIN to the Render URL
# so Fitbit/Google OAuth redirect URIs match the API host.
#API_PUBLIC_ORIGIN="http://localhost:3001"

# Opt-in reminders: evaluate enrolled challenges near this local clock hour (`0`-`23`)
#REMINDER_NOTIFICATION_HOUR_LOCAL=17

# Optional: platform cron instead of in-process hourly sweep (multi-instance prod)
#REMINDER_USE_EXTERNAL_CRON=true
#REMINDER_CRON_SECRET="min-16-char-secret-for-bearer-cron"

# ─── Timezones ────────────────────────────────────────────────────────────────
DEFAULT_CHALLENGE_TZ="America/Chicago"

# Seed admin password (dev only — leave unset in production; Render auto-generates)
# ADMIN_PASSWORD="password123"

# ---------------------------------------------------------------------------
# Email (transactional — password reset, email verification)
# Priority: RESEND_API_KEY > SMTP_* > dev-mode log
# ---------------------------------------------------------------------------
# Option A: Resend (recommended) — get an API key at resend.com
# RESEND_API_KEY=re_...
# SMTP_FROM="StepSprint <noreply@yourdomain.com>"

# Option B: Raw SMTP (SendGrid, Postmark, SES, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-password
# SMTP_FROM="StepSprint <noreply@yourdomain.com>"

# ---------------------------------------------------------------------------
# Push notifications (Web Push / VAPID)
# Generate keys: npx web-push generate-vapid-keys
# ---------------------------------------------------------------------------
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# ---------------------------------------------------------------------------
# OAuth integrations (optional — omit to disable Fitbit / Google Fit connect)
# Register redirect URIs in each provider's console against API_PUBLIC_ORIGIN (or APP_ORIGIN with Vite proxy).
# Fitbit examples:
#   http://localhost:3001/api/integrations/fitbit/callback       (explicit API origin)
#   https://stepsprint-api.onrender.com/api/integrations/fitbit/callback
# ---------------------------------------------------------------------------
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Garmin Connect Developer Program (OAuth 2 + PKCE; requires approved developer app).
# Register this exact redirect against your API origin:
#   {API_PUBLIC_ORIGIN}/api/integrations/garmin/callback
# Optional space-separated Garmin authorize scopes when your registration requires passing scope:
#GARMIN_OAUTH_SCOPE=

# GARMIN_CLIENT_ID=
# GARMIN_CLIENT_SECRET=

# Optional: expose Swagger in production (default off when NODE_ENV=production)
# OPENAPI_DOCS_ENABLED=true

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
# LOG_LEVEL=info   # trace | debug | info | warn | error (default: info)
# SENTRY_DSN=
# Optional explicit release for Sentry + /api/health (else derived from RENDER_GIT_COMMIT, GITHUB_SHA, etc.)
# SENTRY_RELEASE=stepsprint-api@abc1234
# VITE_SENTRY_DSN=
# Set at Vite build time for browser release tracking (or rely on VERCEL_GIT_COMMIT_SHA / GITHUB_SHA in vite.config)
# VITE_SENTRY_RELEASE=stepsprint-client@abc1234
# VITE_POSTHOG_KEY=
# VITE_API_URL=
