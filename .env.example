# Active dev DB: SQLite (see prisma/schema.prisma, uses @prisma/adapter-better-sqlite3)
DATABASE_URL="file:./dev.db"

# Planned production DB: PostgreSQL. When migrating, swap prisma/schema.prisma
# with prisma/schema.postgresql.prisma and uncomment the line below.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stepsprint?schema=public"

JWT_SECRET="change-me-to-a-long-random-secret"
APP_ORIGIN="http://localhost:5173"
DEFAULT_CHALLENGE_TZ="America/Chicago"

# OAuth integrations (optional — omit to disable Fitbit / Google Fit connect)
# Register redirect URIs in each provider's developer console:
#   Fitbit:     {APP_ORIGIN}/api/integrations/fitbit/callback
#   Google Fit: {APP_ORIGIN}/api/integrations/google-fit/callback
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
