# ─── Database ────────────────────────────────────────────────────────────────
# Active dev DB: SQLite (prisma/schema.prisma, @prisma/adapter-better-sqlite3)
DATABASE_URL="file:./dev.db"

# Planned production DB: PostgreSQL. When migrating, copy
# server/prisma/schema.postgresql.prisma over server/prisma/schema.prisma and
# uncomment the line below. Then run: npx prisma migrate deploy
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stepsprint?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
# Must be at least 16 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# ─── CORS ─────────────────────────────────────────────────────────────────────
APP_ORIGIN="http://localhost:5173"

# ─── Timezones ────────────────────────────────────────────────────────────────
DEFAULT_CHALLENGE_TZ="America/Chicago"

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Without SMTP config, emails are logged to the console in dev mode only.
# Any SMTP provider works. Recommended for production: Resend (resend.com)
#
# Resend SMTP relay settings:
#   SMTP_HOST="smtp.resend.com"
#   SMTP_PORT="587"
#   SMTP_USER="resend"
#   SMTP_PASS="re_your_api_key_here"
#   SMTP_FROM="noreply@yourdomain.com"
#
# SendGrid:
#   SMTP_HOST="smtp.sendgrid.net"
#   SMTP_PORT="587"
#   SMTP_USER="apikey"
#   SMTP_PASS="SG.your_api_key_here"
#   SMTP_FROM="noreply@yourdomain.com"
#
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="noreply@yourdomain.com"

# ─── Web Push / VAPID ─────────────────────────────────────────────────────────
# Required to enable push notifications. Generate a key pair once with:
#   cd server && npx web-push generate-vapid-keys
# Then copy the output below. The public key is also served to browser clients.
#
# VAPID_PUBLIC_KEY="BExample_public_key_base64url_encoded_here"
# VAPID_PRIVATE_KEY="example_private_key_base64url_encoded_here"
# VAPID_SUBJECT="mailto:admin@yourdomain.com"

# ─── OAuth integrations ───────────────────────────────────────────────────────
# Optional — omit to disable Fitbit / Google Fit connect.
# Register redirect URIs in each provider's developer console:
#   Fitbit:     {APP_ORIGIN}/api/integrations/fitbit/callback
#   Google Fit: {APP_ORIGIN}/api/integrations/google-fit/callback
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL="info"   # trace | debug | info | warn | error (default: info)

# ─── Error tracking (Sentry) ──────────────────────────────────────────────────
# Both values are no-ops if unset. Get DSNs from sentry.io project settings.
# SENTRY_DSN="https://example@o0.ingest.sentry.io/0"
# VITE_SENTRY_DSN="https://example@o0.ingest.sentry.io/0"

# ─── Analytics (PostHog) ──────────────────────────────────────────────────────
# Client-only. Silently disabled if unset.
# VITE_POSTHOG_KEY="phc_your_project_api_key"

# ─── API URL (client only) ────────────────────────────────────────────────────
# In dev the Vite proxy handles /api → localhost:3001, so this is optional.
# Set in production to point the client at the deployed server.
# VITE_API_URL="https://api.yourdomain.com"
